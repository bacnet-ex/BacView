{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bacview",
  "mainBinaryName": "bacview",
  "version": "0.1.0",
  "identifier": "com.bacnet-ex.bacview",
  "build": {},
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "target/rel": "rel"
    },
    "linux": {
      "deb": {
        "desktopTemplate": "linux/BacView.desktop"
      }
    },
		"macOS": {
			"bundleName": "BacView"
		},
    "windows": {
      "nsis": {
        "template": "windows/installer.nsi"
      }
    }
  }
}
