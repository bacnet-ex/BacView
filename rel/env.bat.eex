@echo off

set RELEASE_DISTRIBUTION=none

if not defined PHX_SERVER set PHX_SERVER=true
if not defined PORT set PORT=4000

if not defined SECRET_KEY_BASE (
    if exist "%RELEASE_ROOT%\.env" (
        for /f "usebackq tokens=1,* delims==" %%a in ("%RELEASE_ROOT%\.env") do (
            if not "%%a"=="" if not "%%a:~0,1%"=="#" (
                set "%%a=%%b"
            )
        )
    )
)
