# BacView local configuration

# Phoenix HTTP port
PORT=4000

# Start web server in release mode
PHX_SERVER=true

# Optional: override path for UI-persisted BACnet stack settings (default: priv/runtime_settings.json)
# BACVIEW_SETTINGS_PATH=/var/lib/bacview/runtime_settings.json

# Max parallel individual ReadProperty streams (default 8). Use 1 if old devices are overwhelmed.
# BACVIEW_PROPERTY_READ_CONCURRENCY=8